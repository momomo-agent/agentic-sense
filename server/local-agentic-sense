#!/usr/bin/env bash
# local-agentic-sense — one command, local speech recognition server
#
# Usage:
#   ./local-agentic-sense              # start on default port 18906
#   ./local-agentic-sense --port 8080  # custom port
#
# First run downloads ~900MB model. Subsequent runs start in seconds.
# Auto-detects: Apple MPS (M1/M2/M3/M4) > NVIDIA CUDA > CPU

set -e

PORT="${1:-18906}"
[[ "$1" == "--port" ]] && PORT="${2:-18906}"

DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"
SERVER="$DIR/.sensevoice-server.py"

# ── Colors ────────────────────────────────────────────────────────
R='\033[0;31m' G='\033[0;32m' Y='\033[0;33m' B='\033[0;34m' N='\033[0m'

echo -e "${B}🎤 local-agentic-sense${N}"
echo ""

# ── Check Python ──────────────────────────────────────────────────
if ! command -v python3 &>/dev/null; then
  echo -e "${R}✗${N} Python 3 not found"
  echo "  macOS:  brew install python3"
  echo "  Ubuntu: sudo apt install python3 python3-pip python3-venv"
  exit 1
fi
echo -e "${G}✓${N} Python $(python3 --version 2>&1 | cut -d' ' -f2)"

# ── Check ffmpeg ──────────────────────────────────────────────────
if ! command -v ffmpeg &>/dev/null; then
  echo -e "${Y}⟳${N} Installing ffmpeg..."
  if [[ "$OSTYPE" == darwin* ]] && command -v brew &>/dev/null; then
    brew install ffmpeg
  elif command -v apt &>/dev/null; then
    sudo apt update -qq && sudo apt install -y -qq ffmpeg
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y -q ffmpeg
  else
    echo -e "${R}✗${N} Install ffmpeg manually"; exit 1
  fi
fi
echo -e "${G}✓${N} ffmpeg"

# ── Venv + deps ───────────────────────────────────────────────────
if [ ! -d "$VENV" ]; then
  echo -e "${Y}⟳${N} Creating virtual environment..."
  python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"

if ! python3 -c "import funasr" 2>/dev/null; then
  echo -e "${Y}⟳${N} Installing dependencies (first run, may take a few minutes)..."
  pip install --upgrade pip
  pip install funasr modelscope torch
fi
echo -e "${G}✓${N} Dependencies ready"

# ── Inline server script ─────────────────────────────────────────
cat > "$SERVER" << 'PYEOF'
import os, sys, time, json, re, tempfile, platform
from http.server import HTTPServer, BaseHTTPRequestHandler
os.environ['PYTORCH_ENABLE_MPS_FALLBACK'] = '1'
os.environ['FUNASR_LOG_LEVEL'] = 'ERROR'

def detect_device():
    import torch
    if hasattr(torch.backends, 'mps') and torch.backends.mps.is_available(): return 'mps'
    if torch.cuda.is_available(): return 'cuda'
    return 'cpu'

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 18906

print("  Loading models...", flush=True)
t0 = time.time()
from funasr import AutoModel
vad = AutoModel(model='iic/speech_fsmn_vad_zh-cn-16k-common-pytorch', device='cpu', disable_update=True)
DEVICE = detect_device()
stt = AutoModel(model='iic/SenseVoiceSmall', device=DEVICE, disable_update=True)

# Warmup
wp = os.path.join(tempfile.gettempdir(), 'sv-warmup.wav')
os.system(f'ffmpeg -y -f lavfi -i "sine=frequency=440:duration=1" -ar 16000 -ac 1 "{wp}" 2>/dev/null')
if os.path.exists(wp):
    stt.generate(input=wp, language='zh', use_itn=True)
    os.unlink(wp)

class H(BaseHTTPRequestHandler):
    def log_message(self, *a): pass
    def _cors(self):
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'POST, GET, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
    def do_OPTIONS(self):
        self.send_response(204); self._cors(); self.end_headers()
    def do_GET(self):
        if self.path == '/health':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json'); self._cors(); self.end_headers()
            self.wfile.write(json.dumps({'ok': True, 'model': 'SenseVoiceSmall+VAD', 'device': DEVICE}).encode())
        else: self.send_response(404); self.end_headers()
    def do_POST(self):
        if self.path != '/transcribe': self.send_response(404); self.end_headers(); return
        audio = self.rfile.read(int(self.headers.get('Content-Length', 0)))
        ct = self.headers.get('Content-Type', '')
        ext = 'webm' if 'webm' in ct else ('mp3' if 'mp3' in ct or 'mpeg' in ct else 'wav')
        with tempfile.NamedTemporaryFile(suffix=f'.{ext}', delete=False) as f: f.write(audio); tmp = f.name
        wav = tmp
        if ext != 'wav':
            wav = tmp + '.wav'
            os.system(f'ffmpeg -y -i "{tmp}" -ar 16000 -ac 1 -c:a pcm_s16le "{wav}" 2>/dev/null')
        try:
            t1 = time.time()
            vr = vad.generate(input=wav)
            segs = [s for s in (vr[0].get('value', []) if vr else []) if (s[1]-s[0]) > 300]
            if not segs:
                self.send_response(200); self.send_header('Content-Type', 'application/json')
                self._cors(); self.end_headers()
                self.wfile.write(json.dumps({'text': '', 'vad': False}).encode()); return
            res = stt.generate(input=wav, language='zh', use_itn=True)
            text = re.sub(r'<\|[^|]*\|>', '', res[0].get('text', '')).strip() if res else ''
            total = time.time() - t1
            print(f'  "{text}" ({total:.2f}s)', flush=True)
            self.send_response(200); self.send_header('Content-Type', 'application/json')
            self._cors(); self.end_headers()
            self.wfile.write(json.dumps({'text': text, 'vad': True, 'time': round(total, 2)}).encode())
        except Exception as e:
            self.send_response(500); self.send_header('Content-Type', 'application/json')
            self._cors(); self.end_headers()
            self.wfile.write(json.dumps({'error': str(e)}).encode())
        finally:
            for p in set([tmp, wav]):
                try: os.unlink(p)
                except: pass

import socketserver
socketserver.TCPServer.allow_reuse_address = True
srv = HTTPServer(('0.0.0.0', PORT), H)
print(f"\n\033[0;32m✓ Ready\033[0m on http://0.0.0.0:{PORT} ({DEVICE}, {time.time()-t0:.1f}s)", flush=True)
print(f"  POST /transcribe  — send audio, get text")
print(f"  GET  /health      — check status\n")
srv.serve_forever()
PYEOF

# ── Start ─────────────────────────────────────────────────────────
echo ""
echo -e "${G}✓${N} All set. Starting server on port ${PORT}..."
echo ""
python3 "$SERVER" "$PORT"
